<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E1E">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="←"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="人格与记忆"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 人格状态 -->
            <TextView
                android:id="@+id/tv_persona_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <!-- 人格摘要 -->
            <TextView
                android:id="@+id/tv_soul_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="加载中..."
                android:textSize="12sp"
                android:textColor="#888888"
                android:fontFamily="monospace"
                android:layout_marginBottom="12dp" />

            <!-- 人格选择器 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="当前人格"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <Spinner
                    android:id="@+id/spinner_persona"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/edit_text_bg"
                    android:padding="12dp" />

                <Button
                    android:id="@+id/btn_switch_persona"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="切换"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#FF9800" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_import_persona"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="导入人格包"
                android:layout_marginBottom="8dp"
                android:backgroundTint="#9C27B0" />

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginVertical="8dp" />

            <!-- 记忆健康检查 -->
            <Button
                android:id="@+id/btn_memory_health"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🧠 记忆健康检查"
                android:layout_marginTop="8dp"
                android:backgroundTint="#00BCD4" />

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginVertical="8dp" />

            <!-- 头像设置 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎨 对话头像"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <ImageView
                    android:id="@+id/iv_avatar_preview"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/edit_text_bg" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">

                    <Button
                        android:id="@+id/btn_pick_avatar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="选择新头像"
                        style="?android:attr/buttonBarButtonStyle" />

                    <Button
                        android:id="@+id/btn_reset_avatar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="恢复默认"
                        style="?android:attr/buttonBarButtonStyle" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_avatar_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:paddingBottom="8dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
