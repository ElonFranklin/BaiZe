<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E1E">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#2A2A2A">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="←"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💰 我的收入"
            android:textSize="20sp"
            android:textColor="#FFD700"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp">

            <!-- 等级信息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#2A2A2A"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <!-- 创作者等级 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="创作者等级"
                        android:textSize="12sp"
                        android:textColor="#AAAAAA" />

                    <TextView
                        android:id="@+id/tv_creator_level"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lv.1 初级"
                        android:textSize="16sp"
                        android:textColor="#FFD700"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_share_rate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="分成 70%"
                        android:textSize="12sp"
                        android:textColor="#4CAF50" />
                </LinearLayout>

                <!-- 审核者等级 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="审核者等级"
                        android:textSize="12sp"
                        android:textColor="#AAAAAA" />

                    <TextView
                        android:id="@+id/tv_reviewer_level"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lv.1 初级"
                        android:textSize="16sp"
                        android:textColor="#FFD700"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_allowance_rate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¥0.5/件"
                        android:textSize="12sp"
                        android:textColor="#4CAF50" />
                </LinearLayout>
            </LinearLayout>

            <!-- 余额概览 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#2A2A2A"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <!-- 可提现 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="可提现"
                        android:textSize="12sp"
                        android:textColor="#AAAAAA" />

                    <TextView
                        android:id="@+id/tv_coins"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¥0"
                        android:textSize="20sp"
                        android:textColor="#FFD700"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 冻结 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="冻结中"
                        android:textSize="12sp"
                        android:textColor="#AAAAAA" />

                    <TextView
                        android:id="@+id/tv_frozen_coins"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¥0"
                        android:textSize="20sp"
                        android:textColor="#FF9800"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- 提现按钮 -->
            <Button
                android:id="@+id/btn_withdraw"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="💰 申请提现（最低10硬币）"
                android:textSize="16sp"
                android:backgroundTint="#FF9800"
                android:layout_marginBottom="24dp" />

            <!-- 收益明细标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="收益明细"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- 收益记录列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_earnings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginVertical="16dp" />

            <!-- 提现记录标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="提现记录"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- 提现记录列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_withdraw"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <!-- 空状态 -->
            <TextView
                android:id="@+id/tv_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="暂无记录"
                android:textColor="#888888"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone" />

            <!-- 提现说明 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💡 提现说明：\n• 最低提现10硬币（1硬币=¥1）\n• 推广期免手续费\n• 每月1日/15日统一处理，T+3到账"
                android:textSize="12sp"
                android:textColor="#888888"
                android:background="#2A2A2A"
                android:padding="12dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
