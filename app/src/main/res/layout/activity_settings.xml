<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#1E1E1E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 返回按钮 + 标题 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="返回"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="API 设置"
                android:textSize="24sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 配置选择 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="选择配置"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinner_config"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- 配置名称 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="配置名称"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="例如: MiniMax-2.7 / OpenAI-4"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginVertical="8dp" />

        <!-- 思考模式 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="思考模式（MiniMax 2.7 支持）"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinner_reasoning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />


    <!-- 推理模式 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="推理模式"
        android:textSize="14sp"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/spinner_model_mode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/edit_text_bg"
        android:padding="12dp"
        android:layout_marginBottom="16dp" />

        <!-- ==================== 对话档位 ==================== -->

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginVertical="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="对话档位"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_tier_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="标准模式：平衡速度和质量"
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinner_chat_tier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- TTS 语速调节 -->
        <TextView
            android:id="@+id/tv_tts_speed_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="语速: 1.0x"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/seek_tts_speed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="30"
            android:progress="10"
            android:layout_marginBottom="16dp" />

        <!-- ==================== 本地模型库 ==================== -->

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginVertical="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="本地模型库"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- 本地模型选择 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="选择本地模型"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/layout_local_model_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Spinner
                android:id="@+id/spinner_local_model"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp" />

            <Button
                android:id="@+id/btn_refresh_models"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔄"
                android:layout_marginStart="8dp"
                android:backgroundTint="#607D8B" />
        </LinearLayout>

        <!-- 模型状态 -->
        <TextView
            android:id="@+id/tv_local_model_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginBottom="16dp" />

        <!-- ==================== 云端 API ==================== -->

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginVertical="8dp" />

        <!-- Provider 名称 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Provider（自动识别）"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_provider_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="自动从 URL 识别"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:enabled="false"
            android:layout_marginBottom="16dp" />

        <!-- Base URL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Base URL"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_base_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="https://api.openai.com"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- API Key -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="API Key"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_api_key"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="sk-..."
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:inputType="textPassword"
            android:layout_marginBottom="16dp" />

        <!-- Model -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Model"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_model"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="gpt-4o-mini / glm-4-flash / ..."
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:layout_marginBottom="24dp" />

        <!-- 状态显示 -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="未配置云端 API"
            android:textSize="14sp"
            android:textColor="#4CAF50"
            android:layout_marginBottom="16dp" />

        <!-- 进度条 -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- 按钮组 -->

        <!-- 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="保存"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#4CAF50" />

            <Button
                android:id="@+id/btn_save_as"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="新增"
                android:layout_marginHorizontal="4dp"
                android:backgroundTint="#FF9800" />

            <Button
                android:id="@+id/btn_test"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="测试"
                android:layout_marginHorizontal="4dp"
                android:backgroundTint="#2196F3" />

            <Button
                android:id="@+id/btn_clear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="删除"
                android:layout_marginStart="4dp"
                android:backgroundTint="#FF5252" />
        </LinearLayout>

    <!-- 剪贴板导入导出 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/btn_import_clipboard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="从剪贴板导入"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#E91E63" />

        <Button
            android:id="@+id/btn_export_clipboard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="导出到剪贴板"
            android:layout_marginStart="4dp"
            android:backgroundTint="#9C27B0" />
    </LinearLayout>

        <!-- 对话管理 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btn_export_chat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="导出对话"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#2196F3" />

            <Button
                android:id="@+id/btn_import_chat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="导入对话"
                android:layout_marginHorizontal="4dp"
                android:backgroundTint="#4CAF50" />

            <Button
                android:id="@+id/btn_clear_chat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="清空对话"
                android:layout_marginStart="4dp"
                android:backgroundTint="#FF5252" />
        </LinearLayout>

        <!-- 记忆健康 -->
        <Button
            android:id="@+id/btn_memory_health"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🧠 记忆健康检查"
            android:layout_marginTop="8dp"
            android:backgroundTint="#00BCD4" />

        <!-- 搜索对话 -->
        <Button
            android:id="@+id/btn_search_chat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔍 搜索对话"
            android:layout_marginTop="8dp"
            android:backgroundTint="#795548" />

        <!-- 商城入口 -->
        <Button
            android:id="@+id/btn_shop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💎 商城"
            android:layout_marginTop="8dp"
            android:backgroundTint="#7C4DFF" />

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginVertical="16dp" />

        <!-- 人格包管理 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="人格包管理"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- 人格状态 -->
        <TextView
            android:id="@+id/tv_persona_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#4CAF50"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_soul_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="加载中..."
            android:textSize="12sp"
            android:textColor="#888888"
            android:fontFamily="monospace"
            android:layout_marginBottom="12dp" />

        <!-- 人格选择器 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="当前人格"
            android:textSize="14sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Spinner
                android:id="@+id/spinner_persona"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp" />

            <Button
                android:id="@+id/btn_switch_persona"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="切换"
                android:layout_marginStart="8dp"
                android:backgroundTint="#FF9800" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_export_soul"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📤 导出人格包"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#9C27B0" />

            <Button
                android:id="@+id/btn_import_soul"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📥 导入人格包"
                android:layout_marginStart="8dp"
                android:backgroundTint="#00BCD4" />
        </LinearLayout>
        <!-- 灵魂档案 -->
        <Button
            android:id="@+id/btn_soul_files"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📝 灵魂档案"
            android:layout_marginTop="12dp"
            android:backgroundTint="#607D8B" />

        <!-- 头像设置 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎨 对话头像"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingTop="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/iv_avatar_preview"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:scaleType="centerCrop"
                android:background="@drawable/edit_text_bg"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <Button
                    android:id="@+id/btn_pick_avatar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="选择新头像"
                    style="?android:attr/buttonBarButtonStyle"/>

                <Button
                    android:id="@+id/btn_reset_avatar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="恢复默认"
                    style="?android:attr/buttonBarButtonStyle"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_avatar_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:paddingBottom="8dp"/>

    </LinearLayout>
</ScrollView>
