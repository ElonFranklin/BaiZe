<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E1E">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="←"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="模型配置"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 推理模式 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="推理模式"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinner_model_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginVertical="8dp" />

            <!-- 云端 API 配置 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="云端 API 配置"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- 配置选择 -->
            <Spinner
                android:id="@+id/spinner_config"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"
                android:layout_marginBottom="12dp" />

            <!-- 配置名称 -->
            <EditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="配置名称"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"
                android:layout_marginBottom="8dp" />

            <!-- Base URL -->
            <EditText
                android:id="@+id/et_base_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="https://api.openai.com"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"
                android:layout_marginBottom="8dp" />

            <!-- API Key -->
            <EditText
                android:id="@+id/et_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="sk-..."
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"
                android:inputType="textPassword"
                android:layout_marginBottom="8dp" />

            <!-- Model -->
            <EditText
                android:id="@+id/et_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="gpt-4o-mini / glm-4-flash"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"
                android:layout_marginBottom="8dp" />

            <!-- 思考模式 -->
            <Spinner
                android:id="@+id/spinner_reasoning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"
                android:layout_marginBottom="12dp" />

            <!-- 状态 -->
            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="未配置云端 API"
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:layout_marginBottom="12dp" />

            <!-- 剪贴板导入/导出 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btn_import_clipboard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="剪贴板导入"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="#7E57C2" />

                <Button
                    android:id="@+id/btn_export_clipboard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="剪贴板导出"
                    android:layout_marginStart="4dp"
                    android:backgroundTint="#5C6BC0" />
            </LinearLayout>

            <!-- 操作按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_save"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="保存"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="#4CAF50" />

                <Button
                    android:id="@+id/btn_save_as"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="新增"
                    android:layout_marginHorizontal="4dp"
                    android:backgroundTint="#FF9800" />

                <Button
                    android:id="@+id/btn_test"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="测试"
                    android:layout_marginHorizontal="4dp"
                    android:backgroundTint="#2196F3" />

                <Button
                    android:id="@+id/btn_clear"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="删除"
                    android:layout_marginStart="4dp"
                    android:backgroundTint="#FF5252" />
            </LinearLayout>

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginVertical="16dp" />

            <!-- 本地模型库 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="本地模型库"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/layout_local_model_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Spinner
                    android:id="@+id/spinner_local_model"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/edit_text_bg"
                    android:padding="12dp" />

                <Button
                    android:id="@+id/btn_refresh_models"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔄"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#607D8B" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_local_model_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
