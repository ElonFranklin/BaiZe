<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 网络权限：云端推理 / 模型下载 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 录音权限：语音输入 -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- 存储权限：旧版 Android 模型文件读取 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29" />
    <!-- Android 11+ 使用系统文件选择器，不再申请所有文件访问权限 -->

    <!-- 声明可查询的 TTS 与语音识别服务 -->
    <queries>
        <intent>
            <action android:name="android.speech.tts.TextToSpeech.Engine.ACTION_CHECK_TTS_DATA" />
        </intent>
        <intent>
            <action android:name="android.speech.tts.TextToSpeech.Engine.ACTION_INSTALL_TTS_DATA" />
        </intent>
        <intent>
            <action android:name="android.intent.action.RECOGNIZE_SPEECH" />
        </intent>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
        <package android:name="com.google.android.tts" />
        <package android:name="com.google.android.googlequicksearchbox" />
    </queries>

    <application
        android:name=".BaizeApplication"
        android:allowBackup="false"
        android:label="白泽"
        android:supportsRtl="true"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.Baize">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.shop.EditPersonaActivity"
            android:theme="@style/Theme.Baize" />

        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:label="API 设置"
            android:theme="@style/Theme.Baize.AppCompat" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name=".ui.settings.SoulFilesActivity"
            android:exported="false"
            android:label="灵魂档案"
            android:theme="@style/Theme.Baize.AppCompat" />

        <activity
            android:name=".comm.ui.CommTestActivity"
            android:exported="false"
            android:label="通信测试"
            android:theme="@style/Theme.Baize.AppCompat" />

        <activity
            android:name=".ui.settings.SoulEditorActivity"
            android:exported="false"
            android:label="编辑灵魂文件"
            android:theme="@style/Theme.Baize.AppCompat"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.auth.AuthActivity"
            android:exported="false"
            android:label="登录"
            android:theme="@style/Theme.Baize.AppCompat" />

        <activity
            android:name=".ui.shop.ShopActivity"
            android:exported="false"
            android:label="商城"
            android:theme="@style/Theme.Baize.AppCompat" />

        <activity
            android:name=".ui.shop.RechargeActivity"
            android:exported="false"
            android:label="充值"
            android:theme="@style/Theme.Baize.AppCompat" />

        <activity
            android:name=".ui.shop.IncomeActivity"
            android:exported="false"
            android:label="我的收入"
            android:theme="@style/Theme.Baize.AppCompat" />

        <activity
            android:name=".ui.shop.SubmitPersonaActivity"
            android:exported="false"
            android:label="提交人格包"
            android:theme="@style/Theme.Baize.AppCompat" />

        <activity
            android:name=".ui.shop.MyReviewsActivity"
            android:exported="false"
            android:label="我的审核"
            android:theme="@style/Theme.Baize.AppCompat" />

        <activity
            android:name=".ui.settings.SettingsHubActivity"
            android:exported="false"
            android:label="设置"
            android:theme="@style/Theme.Baize.AppCompat" />
        <activity
            android:name=".ui.settings.ChatSettingsActivity"
            android:exported="false"
            android:label="对话设置"
            android:theme="@style/Theme.Baize.AppCompat" />
        <activity
            android:name=".ui.settings.VoiceSettingsActivity"
            android:exported="false"
            android:label="语音设置"
            android:theme="@style/Theme.Baize.AppCompat" />
        <activity
            android:name=".ui.settings.PersonaSettingsActivity"
            android:exported="false"
            android:label="人格与记忆"
            android:theme="@style/Theme.Baize.AppCompat" />
        <activity
            android:name=".ui.settings.ModelSettingsActivity"
            android:exported="false"
            android:label="模型配置"
            android:theme="@style/Theme.Baize.AppCompat" />
        <activity
            android:name=".ui.settings.StorageSettingsActivity"
            android:exported="false"
            android:label="存储与安全"
            android:theme="@style/Theme.Baize.AppCompat" />
        <activity
            android:name=".ui.settings.AboutSettingsActivity"
            android:exported="false"
            android:label="关于"
            android:theme="@style/Theme.Baize.AppCompat" />
    
        <activity
            android:name=".ui.shop.MyPendingActivity"
            android:theme="@style/Theme.Baize" />

        <activity
            android:name=".ui.shop.MyApprovedActivity"
            android:theme="@style/Theme.Baize" />
</application>
</manifest>



