# BaiZe Server Environment Variables

# Server
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baize
DB_USER=baize
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=change-this-to-a-random-string-in-production

# Redis (for rate limiting, caching)
REDIS_URL=redis://localhost:6379

# SMS (Aliyun / Tencent)
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=BaiZe
SMS_TEMPLATE_CODE=

# Payment
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://your-domain.com/api/v1/token/recharge/notify

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Logging
LOG_LEVEL=info
